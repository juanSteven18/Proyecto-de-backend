<!DOCTYPE html>
<html>
<head>
    <title><%= title %></title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
</head>
<body>
   <%- include('parcial/navbar') %>

    <h1>Ficha Técnica: <%= pelicula.titulo %></h1>
    <div style="border: 1px solid #ccc; padding: 20px; border-radius: 8px; font-family: Arial, sans-serif; background: #fafafa;">
        <p><strong>Código Único (ID):</strong> <code style="background:#eee; padding:2px 5px;"><%= pelicula.id %></code></p>
        <p><strong>Título Oficial:</strong> <%= pelicula.titulo%></p>
        <p><strong>Tiempo de Duración:</strong> <%= pelicula.duracion %> minutos</p>
        <p><strong>Categoría / Género:</strong> <%= pelicula.genero %></p>
    </div>
    <br>
    <a href="/" style="padding: 6px 12px; background:#6c757d; color:white; text-decoration:none; border-radius:4px;">⬅ Volver al listado</a>
    <a href="/editar/<%= pelicula.id %>" style="padding: 6px 12px; background:#28a745; color:white; text-decoration:none; border-radius:4px; margin-left:10px;">✏️ Editar Película</a>
</body>
</html>