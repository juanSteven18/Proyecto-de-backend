<!DOCTYPE html>
<html>
<head>
    <title><%= title %></title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
</head>
<body>
    <nav style="background: #343a40; padding: 15px; border-radius: 4px; margin-bottom: 20px; font-family: Arial, sans-serif;">
        <a href="/" style="color: white; margin-right: 20px; text-decoration: none; font-weight: bold;">🎬 Películas</a>
        <a href="/salas" style="color: white; margin-right: 20px; text-decoration: none; font-weight: bold;">🏢 Salas</a>
        <a href="/boletos" style="color: white; margin-right: 20px; text-decoration: none; font-weight: bold;">🎟️ Ventas/Boletos</a>
        <a href="/reservaciones" style="color: #28a745; margin-right: 20px; text-decoration: none; font-weight: bold;">📋 Ver Reservaciones</a>
        <a href="/top5" style="color: #ffc107; margin-right: 20px; text-decoration: none; font-weight: bold;">🔥 Top Recientes</a>
        <a href="/filtros/fechas" style="color: #17a2b8; text-decoration: none; font-weight: bold;">📅 Filtro Fechas</a>
    </nav>

    <h1><%= title %></h1>
    <p style="font-family: Arial, sans-serif; color: #6c757d;">Estas son las películas más recientes añadidas a la cartelera.</p>

    <ul style="font-family: Arial, sans-serif; line-height: 1.8;">
        <% lista.forEach((pelicula) => { %>
            <li style="font-size: 1.1em; margin-bottom: 8px;">
                <strong>🎬 <%= pelicula.titulo %></strong> — 
                <span style="color: #007bff;"><%= pelicula.genero %></span> 
                <small style="color: #6c757d;">(<%= pelicula.duracion %> min)</small>
            </li>
        <% }) %>
    </ul>

    <br>
    <a href="/" style="color: #007bff; text-decoration: none; font-weight: bold; font-family: Arial, sans-serif;">Volver al inicio</a>
</body>
</html>