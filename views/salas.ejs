<!DOCTYPE html>
<html>
<head>
    <title><%= title %></title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
</head>
<body>
    <nav style="background: #343a40; padding: 15px; border-radius: 4px; margin-bottom: 20px; font-family: Arial, sans-serif;">
        <a href="/" style="color: white; margin-right: 20px; text-decoration: none; font-weight: bold;">🎬 Películas</a>
        <a href="/salas" style="color: white; margin-right: 20px; text-decoration: none; font-weight: bold;">🏢 Salas</a>
        <a href="/boletos" style="color: white; margin-right: 20px; text-decoration: none; font-weight: bold;">🎟️ Ventas/Boletos</a>
        <a href="/reservaciones" style="color: #28a745; margin-right: 20px; text-decoration: none; font-weight: bold;">📋 Ver Reservaciones</a>
        <a href="/top5" style="color: #ffc107; margin-right: 20px; text-decoration: none; font-weight: bold;">🔥 Top Recientes</a>
        <a href="/filtros/fechas" style="color: #17a2b8; text-decoration: none; font-weight: bold;">📅 Filtro Fechas</a>
    </nav>

    <h1><%= title %></h1>
    
    <div style="background: #f8f9fa; padding: 20px; border-radius: 8px; margin-bottom: 25px; border: 1px solid #dee2e6; font-family: Arial, sans-serif;">
        <h3 style="margin-top: 0;">➕ Registrar Nueva Sala</h3>
        <form action="/salas/guardar" method="POST" style="display: flex; gap: 15px; align-items: center; flex-wrap: wrap;">
            <div>
                <label style="display:block; margin-bottom:5px;">Nombre de la Sala:</label>
                <input type="text" name="nombre" placeholder="Ej: Sala 1 - 3D" required style="padding: 6px; border: 1px solid #ccc; border-radius: 4px;">
            </div>
            <div>
                <label style="display:block; margin-bottom:5px;">Capacidad Máxima:</label>
                <input type="number" name="capacidad" placeholder="Ej: 80" required style="padding: 6px; border: 1px solid #ccc; border-radius: 4px; width: 100px;">
            </div>
            <button type="submit" style="padding: 8px 15px; background: #28a745; color: white; border: none; border-radius: 4px; cursor: pointer; margin-top: 22px; font-weight: bold;">Guardar Sala</button>
        </form>
    </div>

    <table style="width: 100%; border-collapse: collapse; font-family: Arial, sans-serif;">
        <thead>
            <tr style="background-color: #f8f9fa; border-bottom: 2px solid #dee2e6; text-align: left;">
                <th style="padding: 12px;">Identificador de la Sala</th>
                <th style="padding: 12px;">Capacidad de Aforo</th>
                <th style="padding: 12px; text-align: center;">Acciones</th>
            </tr>
        </thead>
        <tbody>
            <% if (listaSalas.length === 0) { %>
                <tr>
                    <td colspan="3" style="padding: 20px; text-align: center; color: #6c757d;">No hay salas registradas actualmente.</td>
                </tr>
            <% } else { %>
                <% listaSalas.forEach((sala) => { %>
                    <tr style="border-bottom: 1px solid #eee;">
                        <td style="padding: 12px;"><strong>🏢 <%= sala.nombre %></strong></td>
                        <td style="padding: 12px;"><span style="background: #e9ecef; padding: 4px 10px; border-radius: 12px; font-size: 0.85em; font-weight: bold;"><%= sala.capacidad %> Butacas</span></td>
                        <td style="padding: 12px; text-align: center;">
                            <a href="/salas/eliminar/<%= sala.id %>" style="color: #dc3545; text-decoration: none; font-weight: bold;" onclick="return confirm('¿Seguro que deseas eliminar esta sala?')">🗑️ Eliminar</a>
                            <td style="padding: 12px; text-align: center;">
    <a href="/salas/editar/<%= sala.id %>" style="color: #28a745; text-decoration: none; font-weight: bold; margin-right: 10px;">✏️ Editar</a>
    <span style="color: #ccc;">|</span>
    <a href="/salas/eliminar/<%= sala.id %>" style="color: #dc3545; text-decoration: none; font-weight: bold; margin-left: 10px;" onclick="return confirm('¿Seguro que deseas eliminar esta sala?')">❌ Eliminar</a>
</td>
                        </td>
                    </tr>
                <% }) %>
            <% } %>
        </tbody>
    </table>
</body>
</html>