<!DOCTYPE html>
<html>
<head>
    <title><%= title %></title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
</head>
<body>
    <nav style="background: #343a40; padding: 15px; border-radius: 4px; margin-bottom: 20px; font-family: Arial, sans-serif;">
        <a href="/" style="color: white; margin-right: 20px; text-decoration: none; font-weight: bold;">🎬 Películas</a>
        <a href="/salas" style="color: white; margin-right: 20px; text-decoration: none; font-weight: bold;">🏢 Salas</a>
        <a href="/boletos" style="color: white; margin-right: 20px; text-decoration: none; font-weight: bold;">🎟️ Ventas/Boletos</a>
        <a href="/reservaciones" style="color: #28a745; margin-right: 20px; text-decoration: none; font-weight: bold;">📋 Ver Reservaciones</a>
        <a href="/top5" style="color: #ffc107; margin-right: 20px; text-decoration: none; font-weight: bold;">🔥 Top Recientes</a>
        <a href="/filtros/fechas" style="color: #17a2b8; text-decoration: none; font-weight: bold;">📅 Filtro Fechas</a>
    </nav>

    <h1><%= title %></h1>
<div style="background: #f8f9fa; padding: 20px; border-radius: 8px; margin-bottom: 25px; border: 1px solid #dee2e6; font-family: Arial, sans-serif;">
    <h3 style="margin-top: 0; color: #343a40; display: flex; align-items: center; gap: 8px;">🎟️ Registrar Nueva Venta de Boleto</h3>
    
    <form action="/boletos/guardar" method="POST" style="display: flex; flex-wrap: wrap; gap: 15px; align-items: flex-end;">
        
        <div style="flex: 2; min-width: 200px;">
            <label style="display: block; font-weight: bold; margin-bottom: 5px; font-size: 0.9em; color: #495057;">Película en Cartelera:</label>
            <select name="peliculaId" required style="width: 100%; padding: 8px; border-radius: 4px; border: 1px solid #ced4da; background: white;">
                <option value="" disabled selected>-- Seleccione Película --</option>
                <% peliculas.forEach(peli => { %>
                    <option value="<%= peli.id %>">🎬 <%= peli.titulo %></option>
                <% }) %>
            </select>
        </div>

        <div style="flex: 1.5; min-width: 180px;">
            <label style="display: block; font-weight: bold; margin-bottom: 5px; font-size: 0.9em; color: #495057;">Sala Asignada:</label>
            <select name="salaId" required style="width: 100%; padding: 8px; border-radius: 4px; border: 1px solid #ced4da; background: white;">
                <option value="" disabled selected>-- Seleccione Sala --</option>
                <% salas.forEach(sala => { %>
                    <option value="<%= sala.id %>">🏢 <%= sala.nombre %> (<%= sala.capacidad %> cap.)</option>
                <% }) %>
            </select>
        </div>

        

        <div style="width: 160px;">
            <label style="display: block; font-weight: bold; margin-bottom: 5px; font-size: 0.9em; color: #495057;">Fecha de Función:</label>
            <input type="date" name="fecha" required style="width: 100%; padding: 7px; border-radius: 4px; border: 1px solid #ced4da; box-sizing: border-box;">
        </div>

        <div>
            <button type="submit" style="padding: 9px 20px; background: #28a745; color: white; border: none; border-radius: 4px; font-weight: bold; cursor: pointer; transition: background 0.2s;">
                ⚡ Emitir Ticket
            </button>
        </div>
    </form>
</div>
    <table style="width: 100%; border-collapse: collapse; font-family: Arial, sans-serif; margin-top: 20px;">
        <thead>
            <tr style="background-color: #f8f9fa; border-bottom: 2px solid #dee2e6; text-align: left;">
                <th style="padding: 12px;">Película Solicitada</th>
                <th style="padding: 12px;">Sala Asignada</th>
                
                <th style="padding: 12px;">Fecha de la Función</th>
                <th style="padding: 12px; text-align: center;">Acciones</th>
            </tr>
        </thead>
        <tbody>
            <% if (listaBoletos.length === 0) { %>
                <tr>
                    <td colspan="5" style="padding: 20px; text-align: center; color: #6c757d;">No se han emitido boletos en el sistema.</td>
                </tr>
            <% } else { %>
                <% listaBoletos.forEach((boleto) => { %>
                    <tr style="border-bottom: 1px solid #eee;">
                        <td style="padding: 12px;"><strong>🎬 <%= bto = boleto.tituloPelicula %></strong></td>
                        <td style="padding: 12px;">🏢 <%= boleto.nombreSala %></td>
                        
                        <td style="padding: 12px; color: #555;"><%= boleto.fecha %></td>
                        <td style="padding: 12px; text-align: center;">
                            <a href="/boletos/eliminar/<%= boleto.id %>" style="color: #dc3545; text-decoration: none; font-weight: bold;" onclick="return confirm('¿Deseas revocar la venta de este boleto?')">❌ Cancelar</a>
                            <td style="padding: 12px; text-align: center;">
    <a href="/boletos/editar/<%= boleto.id %>" style="color: #28a745; text-decoration: none; font-weight: bold; margin-right: 10px;">✏️ Editar</a>
    <span style="color: #ccc;">|</span>
    <a href="/boletos/eliminar/<%= boleto.id %>" style="color: #dc3545; text-decoration: none; font-weight: bold; margin-left: 10px;" onclick="return confirm('¿Deseas cancelar y eliminar este boleto?')">❌ Eliminar</a>
</td>
                        </td>
                    </tr>
                <% }) %>
            <% } %>
        </tbody>
    </table>
</body>
</html>