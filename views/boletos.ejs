<!DOCTYPE html>
<html>
<head>
    <title><%= title %></title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
</head>
<body>
 <%- include('parcial/navbar') %>

    <h1><%= title %></h1>
<div style="background: #f8f9fa; padding: 20px; border-radius: 8px; margin-bottom: 25px; border: 1px solid #dee2e6; font-family: Arial, sans-serif;">
    <h3 style="margin-top: 0; color: #343a40; display: flex; align-items: center; gap: 8px;">🎟️ Registrar Nueva Venta de Boleto</h3>
    
    <form action="/boletos/guardar" method="POST" style="background-color: #ffffff; padding: 25px; border-radius: 8px; border: 1px solid #e2e8f0; max-width: 1000px; margin: 0 auto 30px auto; font-family: Arial, sans-serif;">
    
    <h3 style="margin-top: 0; margin-bottom: 20px; color: #2d3748; display: flex; align-items: center; gap: 8px;">
        🎫 Registrar Nueva Venta de Boleto
    </h3>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin-bottom: 25px;">
        
        <div>
    <label style="display: block; font-weight: bold; margin-bottom: 6px; color: #4a5568;">Película en Cartelera:</label>
    <select name="peliculaId" required style="width: 100%; padding: 10px; border: 1px solid #cbd5e0; border-radius: 6px; background-color: #fff;">
        <option value="" disabled selected>-- Seleccione Película --</option>
        <% peliculas.forEach(pelicula => { %>
            <option value="<%= pelicula.id %>">🎬 <%= pelicula.titulo %></option>
        <% }) %>
    </select>
</div>

       <div>
    <label style="display: block; font-weight: bold; margin-bottom: 6px; color: #4a5568;">Sala Asignada:</label>
    <select name="salaId" required style="width: 100%; padding: 10px; border: 1px solid #cbd5e0; border-radius: 6px; background-color: #fff;">
        <option value="" disabled selected>-- Seleccione Sala --</option>
        <% salas.forEach(sala => { %>
            <option value="<%= sala.id %>">🏢 <%= sala.nombre %></option>
        <% }) %>
    </select>
</div>

        <div>
    <label style="display: block; font-weight: bold; margin-bottom: 6px; color: #4a5568;">Cliente:</label>
    <select name="usuarioId" required style="width: 100%; padding: 10px; border: 1px solid #cbd5e0; border-radius: 6px;">
        <option value="" disabled selected>-- Seleccione Cliente --</option>
        <% usuarios.forEach(u => { %>
            <option value="<%= u.id %>"><%= u.nombre %> (<%= u.email %>)</option>
        <% }) %>
    </select>
</div>

        <div>
            <label style="display: block; font-weight: bold; margin-bottom: 6px; color: #4a5568;">Cantidad de Asientos:</label>
            <input type="number" name="cantidadAsientos" min="1" placeholder="Ej. 2" required style="width: 100%; padding: 10px; border: 1px solid #cbd5e0; border-radius: 6px; box-sizing: border-box;" />
        </div>

        <div>
            <label style="display: block; font-weight: bold; margin-bottom: 6px; color: #4a5568;">Fecha de Función:</label>
            <input type="date" name="fecha" style="width: 100%; padding: 10px; border: 1px solid #cbd5e0; border-radius: 6px; box-sizing: border-box;" />
        </div>

    </div>

    <div style="text-align: right;">
        <button type="submit" style="background-color: #28a745; color: white; padding: 12px 30px; border: none; border-radius: 6px; font-weight: bold; cursor: pointer; transition: background 0.2s;">
            ⚡ Emitir Ticket
        </button>
    </div>

</form>
</div>
    <table style="width: 100%; border-collapse: collapse; font-family: Arial, sans-serif; margin-top: 20px;">
        <thead>
            <tr style="background-color: #f8f9fa; border-bottom: 2px solid #dee2e6; text-align: left;">
                <th style="padding: 12px;">Película Solicitada</th>
                <th style="padding: 12px;">Cliente</th>
                <th style="padding: 12px;">Sala Asignada</th>
                
                <th style="padding: 12px;">Fecha de la Función</th>
                <th style="padding: 12px; text-align: center;">Acciones</th>
            </tr>
        </thead>
        <tbody>
            <% if (listaBoletos.length === 0) { %>
                <tr>
                    <td colspan="5" style="padding: 20px; text-align: center; color: #6c757d;">No se han emitido boletos en el sistema.</td>
                </tr>
            <% } else { %>
                <% listaBoletos.forEach((boleto) => { %>
                    <tr style="border-bottom: 1px solid #eee;">
                        <td>🎬 <%= boleto.funcion && boleto.funcion.pelicula ? boleto.funcion.pelicula.titulo : 'Sin Película' %></td>
                        <td>
                            <%= boleto.usuario ? boleto.usuario.nombre : 'Sin Cliente' %><br>
                <small style="color: #666;"><%= boleto.usuario ? boleto.usuario.email : '' %></small>
                        </td>
                        <td>🏢 <%= boleto.funcion && boleto.funcion.sala ? boleto.funcion.sala.nombre : 'Sin Sala' %></td>
                        <td>📅 <%= boleto.funcion ? boleto.funcion.fecha : 'Sin Fecha' %></td>
                        <td style="padding: 12px; text-align: center;">
                            <a href="/boletos/eliminar/<%= boleto.id %>" style="color: #dc3545; text-decoration: none; font-weight: bold;" onclick="return confirm('¿Deseas revocar la venta de este boleto?')">❌ Cancelar</a>
                            <td style="padding: 12px; text-align: center;">
    <a href="/boletos/editar/<%= boleto.id %>" style="color: #28a745; text-decoration: none; font-weight: bold; margin-right: 10px;">✏️ Editar</a>
    <span style="color: #ccc;">|</span>
    <a href="/boletos/eliminar/<%= boleto.id %>" style="color: #dc3545; text-decoration: none; font-weight: bold; margin-left: 10px;" onclick="return confirm('¿Deseas cancelar y eliminar este boleto?')">❌ Eliminar</a>
</td>
                        </td>
                    </tr>
                <% }) %>
            <% } %>
        </tbody>
    </table>
</body>
</html>