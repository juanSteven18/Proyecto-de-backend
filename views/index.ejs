<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
</head>
<body style="font-family: Arial, sans-serif; background-color: #f4f6f9; color: #333; margin: 0; padding: 20px;">

    <nav style="background: #343a40; padding: 15px; border-radius: 4px; margin-bottom: 20px;">
        <a href="/" style="color: white; margin-right: 20px; text-decoration: none; font-weight: bold;">🎬 Películas</a>
        <a href="/salas" style="color: white; margin-right: 20px; text-decoration: none; font-weight: bold;">🏢 Salas</a>
        <a href="/boletos" style="color: white; margin-right: 20px; text-decoration: none; font-weight: bold;">🎟️ Ventas/Boletos</a>
        <a href="/reservaciones" style="color: #28a745; margin-right: 20px; text-decoration: none; font-weight: bold;">📋 Ver Reservaciones</a>
        <a href="/top5" style="color: #ffc107; margin-right: 20px; text-decoration: none; font-weight: bold;">🔥 Top Recientes</a>
        <a href="/filtros/fechas" style="color: #17a2b8; text-decoration: none; font-weight: bold;">📅 Filtro Fechas</a>
    </nav>

    <h1 style="color: #2c3e50; border-bottom: 2px solid #34495e; padding-bottom: 10px;"><%= title %></h1>

    <div style="background: white; padding: 20px; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); margin-bottom: 30px;">
        <h3 style="margin-top: 0; color: #2c3e50;">Añadir Nueva Película a Cartelera</h3>
        <form action="/guardar" method="POST" style="display: flex; flex-wrap: wrap; gap: 15px;">
            <div style="flex: 1; min-width: 200px;">
                <label style="display: block; margin-bottom: 5px; font-weight: bold;">Título:</label>
                <input type="text" name="titulo" required style="width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;">
            </div>
            <div style="flex: 1; min-width: 150px;">
                <label style="display: block; margin-bottom: 5px; font-weight: bold;">Género:</label>
                <input type="text" name="genero" required style="width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;">
            </div>
            <div style="flex: 1; min-width: 150px;">
                <label style="display: block; margin-bottom: 5px; font-weight: bold;">Duración (min):</label>
                <input type="number" name="duracion" required style="width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;">
            </div>
            <div style="width: 100%;">
                <button type="submit" style="background: #28a745; color: white; border: none; padding: 10px 20px; border-radius: 4px; font-weight: bold; cursor: pointer;">Añadir Película</button>
            </div>
        </form>
    </div>

    <div style="background: white; padding: 20px; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
        <h3 style="margin-top: 0; color: #2c3e50;">Películas en Exhibición</h3>
        
        <% if (lista && lista.length > 0) { %>
            <table style="width: 100%; border-collapse: collapse; margin-top: 10px;">
                <thead>
                    <tr style="background-color: #34495e; color: white; text-align: left;">
                        <th style="padding: 12px; border: 1px solid #ddd;">Título</th>
                        <th style="padding: 12px; border: 1px solid #ddd;">Género</th>
                        <th style="padding: 12px; border: 1px solid #ddd;">Duración</th>
                        <th style="padding: 12px; border: 1px solid #ddd; text-align: center;">Acciones de Control</th>
                    </tr>
                </thead>
                <tbody>
                    <% lista.forEach(pelicula => { %>
                        <tr style="border-bottom: 1px solid #ddd;">
                            <td style="padding: 12px; font-weight: bold;"><%= pelicula.titulo %></td>
                            <td style="padding: 12px;"><%= pelicula.genero %></td>
                            <td style="padding: 12px;"><%= pelicula.duracion %> min</td>
                            <td style="padding: 12px; text-align: center;">
                                <a href="/pelicula/<%= pelicula.id %>" style="margin: 0 5px; color: #007bff; text-decoration: none; font-weight: bold;">👁️ Ver</a>
                                <span style="color: #ccc;">|</span>
                                
                                <a href="/pelicula/<%= pelicula.id %>/funciones" style="margin: 0 5px; color: #17a2b8; text-decoration: none; font-weight: bold;">📅 Funciones</a>
                                <span style="color: #ccc;">|</span>
                                
                                <a href="/editar/<%= pelicula.id %>" style="margin: 0 5px; color: #28a745; text-decoration: none; font-weight: bold;">✏️ Editar</a>
                                <span style="color: #ccc;">|</span>
                                
                                <a href="/eliminar/<%= pelicula.id %>" style="margin: 0 5px; color: #dc3545; text-decoration: none; font-weight: bold;" onclick="return confirm('¿Seguro que deseas eliminar esta película de la cartelera?')">❌ Eliminar</a>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } else { %>
            <p style="color: #7f8c8d; font-style: italic; text-align: center; padding: 20px;">No hay películas registradas en la cartelera actualmente.</p>
        <% } %>
    </div>

</body>
</html>